{
  "name": "Avoid Large 4K Old Movies",
  "includeCustomFormatWhenRenaming": false,
  "specifications": [
    {
      "name": "Movie Year Before 2014",
      "implementation": "ReleaseTitleSpecification",
      "negate": false,
      "required": true,
      "fields": {
        "value": "\\b(19[0-9][0-9]|200[0-9]|201[0-3])\\b"
      }
    },
    {
      "name": "Is 4K",
      "implementation": "ResolutionSpecification",
      "negate": false,
      "required": true,
      "fields": {
        "value": 8
      }
    },
    {
      "name": "Size Over 20GB",
      "implementation": "SizeSpecification",
      "negate": false,
      "required": true,
      "fields": {
        "min": 20,
        "max": 999
      }
    }
  ]
}
