# ============================================================================
# Media Automation Stack - Environment Variables
# ============================================================================
# Copy this file to .env and update with your values
# Command: Copy-Item env.example .env

# ============================================================================
# VPN Configuration (via Gluetun) — works with ANY Gluetun-supported provider
# ============================================================================
# Only qBittorrent routes through the VPN. Gluetun natively supports Mullvad,
# NordVPN, PIA, ProtonVPN, Surfshark, Windscribe, and many more. Full provider
# list + the exact variables each one needs:
#   https://github.com/qdm12/gluetun-wiki/tree/main/setup/providers
#
# Set your provider name and connection type (openvpn or wireguard):
VPN_SERVICE_PROVIDER=mullvad
VPN_TYPE=wireguard

# --- OpenVPN providers (set VPN_TYPE=openvpn) ---
OPENVPN_USER=
OPENVPN_PASSWORD=

# --- WireGuard providers (set VPN_TYPE=wireguard, e.g. Mullvad/ProtonVPN) ---
WIREGUARD_PRIVATE_KEY=
WIREGUARD_ADDRESSES=

# --- Optional: choose server location (provider-based configs) ---
SERVER_COUNTRIES=
SERVER_CITIES=

# --- Bring your own OpenVPN config? (only if your provider isn't built in) ---
# Set VPN_SERVICE_PROVIDER=custom and VPN_TYPE=openvpn above, drop your .ovpn at
# ./vpn-config.ovpn, uncomment the next line, and enable docker-compose.custom-vpn.yml
# via COMPOSE_FILE (see the Docker Configuration section below).
#OPENVPN_CUSTOM_CONFIG=/gluetun/custom.conf

# ============================================================================
# Path Configuration
# ============================================================================
# Root directory for all media server files
# Change this to your desired installation path
# Examples:
#   Linux: /home/username/media-stack or /mnt/storage/media
#   Windows: D:/media
MEDIA_ROOT=/path/to/your/media-stack
CONFIG_ROOT=/path/to/your/media-stack/config
DOWNLOADS_ROOT=/path/to/your/media-stack/downloads

# Media library paths
MOVIES_ROOT=/path/to/your/media-stack/movies
TVSHOWS_ROOT=/path/to/your/media-stack/tvshows
ANIME_ROOT=/path/to/your/media-stack/anime
MANGA_ROOT=/path/to/your/media-stack/manga
PHOTOS_ROOT=/path/to/your/media-stack/photos

# Optional: external storage roots (if you keep iCloud/Google Photos elsewhere)
ICLOUD_ROOT=/path/to/your/icloud/library
ICLOUD_CONFIG_ROOT=/path/to/your/icloud/config
ICLOUD_BACKUP_ROOT=/path/to/your/icloud/library    # used by check-icloud-backup.sh
GOOGLE_PHOTOS_ROOT=/path/to/your/google-photos-library

# ============================================================================
# Service Ports
# ============================================================================
# qBittorrent (routes through Gluetun/VPN)
QBITTORRENT_WEBUI_PORT=8080
QBITTORRENT_PORT_TCP=6881
QBITTORRENT_PORT_UDP=6881

# Prowlarr (Indexer Manager)
PROWLARR_PORT=9696

# Radarr (Movie Manager)
RADARR_PORT=7878

# Sonarr (TV Show Manager)
SONARR_PORT=8989

# Overseerr (Request Management)
OVERSEERR_PORT=5055

# Bazarr (Subtitle Manager)
BAZARR_PORT=6767

# PhotoPrism (Photo and Video Management)
PHOTOPRISM_PORT=2342

# Tautulli (Plex Analytics)
TAUTULLI_PORT=8181

# Scrutiny (Drive Health Monitoring)
SCRUTINY_PORT=8082

# Homepage (Dashboard)
HOMEPAGE_PORT=3000

# Plex ports are standard and don't need configuration

# ============================================================================
# Docker Configuration
# ============================================================================
DOCKER_NETWORK=media-network

# --- Optional features (GPU / custom VPN) ---
# The base stack runs on ANY hardware with no GPU. To layer on optional
# overrides, set COMPOSE_FILE so `docker compose` picks them up automatically:
#   NVIDIA GPU:      COMPOSE_FILE=docker-compose.yml:docker-compose.gpu.yml
#   Custom OpenVPN:  COMPOSE_FILE=docker-compose.yml:docker-compose.custom-vpn.yml
#   Both:            COMPOSE_FILE=docker-compose.yml:docker-compose.gpu.yml:docker-compose.custom-vpn.yml
# Leave commented to run the plain GPU-less, provider-VPN base stack.
#COMPOSE_FILE=docker-compose.yml

# User/Group IDs for file permissions
# Windows: Use 1000 for both
# Linux: Use your actual UID/GID (run: id -u and id -g)
# Pop!_OS: bootstrap.sh will auto-detect and set these
PUID=1000
PGID=1000

# Timezone (see: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
TZ=America/New_York

# ============================================================================
# Optional: Plex Claim Token (for easy server setup)
# ============================================================================
# Get claim token from: https://www.plex.tv/claim/
# Token is valid for 4 minutes - use it immediately after getting it
# Leave empty if setting up Plex manually
PLEX_CLAIM=

# ============================================================================
# Optional: PhotoPrism Admin Password
# ============================================================================
# Set a secure password for PhotoPrism admin account
PHOTOPRISM_ADMIN_PASSWORD=

# ============================================================================
# Optional: iCloud Photo Download (icloudpd)
# ============================================================================
# Apple ID for iCloud (your email address)
ICLOUD_APPLE_ID=

# App-Specific Password (NOT your regular Apple ID password!)
# Generate at: https://appleid.apple.com → Sign-In and Security → App-Specific Passwords
ICLOUD_PASSWORD=

# Synchronisation interval in seconds (default: 86400 = 24 hours)
ICLOUD_SYNC_INTERVAL=86400

# Convert HEIC to JPEG (default: False)
ICLOUD_CONVERT_HEIC=False

# JPEG quality when converting (1-100, default: 90)
ICLOUD_JPEG_QUALITY=90

# Skip check for existing files (default: False)
ICLOUD_SKIP_CHECK=False

# Delete photos from iCloud after download (default: False)
# WARNING: Only enable if you're sure you want to delete from iCloud!
ICLOUD_DELETE_AFTER_DOWNLOAD=False

# ============================================================================
# Kometa (Plex Collection Manager)
# ============================================================================
# Get a free TMDb API key at: https://www.themoviedb.org/settings/api
# Required for franchise and studio collections. Genres/decades/IMDb work without it.
TMDB_API_KEY=

# ============================================================================
# API Keys (for Unpackerr and Homepage widgets)
# ============================================================================
# Find these in each service under Settings → General → API Key
RADARR_API_KEY=
SONARR_API_KEY=
PROWLARR_API_KEY=
OVERSEERR_API_KEY=
TAUTULLI_API_KEY=

# Plex token: visit plex.tv, sign in, open any media item,
# click ··· → Get Info → View XML → grab X-Plex-Token from the URL
PLEX_TOKEN=

# qBittorrent WebUI password (for Homepage widget)
QBITTORRENT_PASSWORD=

# ============================================================================
# Optional: Tailscale (Remote Access)
# ============================================================================
# Get auth key from: https://login.tailscale.com/admin/settings/keys
# Leave empty if not using Tailscale
TAILSCALE_AUTHKEY=

# ============================================================================
# Notes
# ============================================================================
# 1. Only qBittorrent routes through VPN (via Gluetun)
# 2. All other services use direct LAN access
# 3. Use forward slashes (/) in paths, even on Windows
# 4. Don't add trailing slashes to paths
# 5. GPU is optional — enable it via COMPOSE_FILE above (see docs/CROSS_PLATFORM.md)
# 6. Custom .ovpn users: place the file at ./vpn-config.ovpn and enable docker-compose.custom-vpn.yml
